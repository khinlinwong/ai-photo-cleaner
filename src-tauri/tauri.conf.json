{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Photo Cleaner",
  "version": "0.1.0",
  "identifier": "com.aiphotocleaner.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "AI Photo Cleaner",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": false
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "template": "./templates/installer.nsi"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
